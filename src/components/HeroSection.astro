<section class="relative flex h-screen items-center justify-center overflow-hidden text-center">
  <div
    id="hero-background"
    class="absolute inset-0 -z-20 bg-[radial-gradient(circle_at_center,#ebf4ff_0%,#ffffff_100%)]"
  >
  </div>
  <div
