<section class="mb-24 rounded-[20px] bg-[#326ce5] px-8 py-16 text-center text-white">
  <h2 class="mb-4 text-[clamp(2rem,4vw,3rem)]">Стабильность кластера</h2>
  <div
    id="victory-counter"
    class="mx-auto my-12 grid max-w-3xl grid-cols-2 gap-4 md:grid-cols-4 md:gap-8"
  >
    <div
      class="flex w-full flex-col rounded-[10px] bg-[rgba(15,19,22,0.16)] px-4 py-2 md:px-8 md:py-4"
    >
      <span class="text-4xl font-bold tabular-nums md:text-5xl" id="counter-hours">00</span>
      <span class="text-base uppercase tracking-[0.1em] text-white">Часов</span>
    </div>
    <div
      class="flex w-full flex-col rounded-[10px] bg-[rgba(15,19,22,0.16)] px-4 py-2 md:px-8 md:py-4"
    >
      <span class="text-4xl font-bold tabular-nums md:text-5xl" id="counter-minutes">00</span>
      <span class="text-base uppercase tracking-[0.1em] text-white">Минут</span>
    </div>
    <div
      class="flex w-full flex-col rounded-[10px] bg-[rgba(15,19,22,0.16)] px-4 py-2 md:px-8 md:py-4"
    >
      <span class="text-4xl font-bold tabular-nums md:text-5xl" id="counter-seconds">00</span>
      <span class="text-base uppercase tracking-[0.1em] text-white">Секунд</span>
    </div>
    <div
      class="flex w-full flex-col rounded-[10px] bg-[rgba(15,19,22,0.16)] px-4 py-2 md:px-8 md:py-4"
    >
      <span class="text-4xl font-bold tabular-nums md:text-5xl" id="counter-ms">000</span>
      <span class="text-base uppercase tracking-[0.1em] text-white">мс</span>
    </div>
  </div>
  <p class="text-[1.1rem] text-white">Времени прошло с момента последнего Pending пода</p>
</section>
