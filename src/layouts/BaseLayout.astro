---
import globalStyles from "../styles/global.css?inline";

interface Props {
  title?: string;
  description?: string;
}

const { title = "КУБЫПОБЕДА.РФ", description = "Очередной год победы Kubernetes." } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <style is:global set:html={globalStyles}></style>
    <title>{title}</title>
  </head>
  <body class="bg-white font-sans text-[#0f1316] antialiased">
    <slot />
  </body>
</html>
